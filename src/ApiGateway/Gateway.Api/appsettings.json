{
  "Vault": {
    "Address": "http://vault:8200",
    "Token": "ENCRYPTED_VAULT_TOKEN_HERE",
    "MountPoint": "secret",
    "SecretPath": "microservices"
  },
  "ReverseProxy": {
    "Routes": {
      "AuthApiRoute": {
        "ClusterId": "AuthApiCluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "EmployeeApiRoute": {
        "ClusterId": "EmployeeApiCluster",
        "AuthorizationPolicy": "EmployeeOrAdmin",
        "Match": {
          "Path": "/api/employee/{**catch-all}"
        },
        "Metadata": {
          "Timeout": "00:00:30"
        }
      }
    },
    "Clusters": {
      "AuthApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://auth-api-service:8080"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        }
      },
      "EmployeeApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://employee-api-service:8080"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        }
      }
    }
  },
  "HealthChecksUI": {
    "HealthChecks": [
      {
        "Name": "EmployeeService API",
        "Uri": "http://employee-api:8080/health"
      },
      {
        "Name": "AuthService API",
        "Uri": "http://auth-api:8080/health"
      }
    ],
    "EvaluationTimeInSeconds": 10,
    "MinimumSecondsBetweenFailureNotifications": 60
  }
}
